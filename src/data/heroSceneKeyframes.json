      "scale": 1,
      "blowUp": 0
    },
    {
      "id": "connect-breadboard",
      "scroll": 0.333,
      "position": { "x": 0, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 },
      "scale": 1,
      "blowUp": 0
    },
    {
      "id": "adjust-power",
      "scroll": 0.666,
      "position": { "x": 0, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 },
      "scale": 1,
      "blowUp": 0
    },
    {
      "id": "end",
      "scroll": 1,
      "position": { "x": 0, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 },
      "scale": 1,
      "blowUp": 0
