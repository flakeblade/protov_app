{
  "name": "protov_app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://flakeblade.github.io/protov_app/",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prebuild": "mkdir -p public/models && cp src/assets/3d/scene_backup.glb public/models/scene.glb",
    "dev": "vite",
    "dev:mock": "cd mock-device && PROTOV_MOCK_STATE=states/ch1-active.yaml ./scripts/run.sh",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:mock": "cd mock-device && . .venv/bin/activate && python -m pytest",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@mantine/code-highlight": "^8.3.18",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@mantine/notifications": "^8.3.18",
    "@mantine/spotlight": "^8.3.18",
    "@mdx-js/react": "^3.1.1",
    "@react-three/drei": "^10.4.4",
    "@react-three/fiber": "^9.2.0",
    "@tabler/icons-react": "^3.44.0",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.2",
    "gltfpack": "^1.1.0",
    "highlight.js": "^11.11.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "rehype-highlight": "^7.0.2",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.178.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mdx-js/rollup": "^3.1.1",
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.178.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
